{
  "compilerOptions": {
    "declaration": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "../dist",
    "rootDir": ".",
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2021",
    "types": [
      "node"
    ]
  },
  "include": [
    "generated/**/*.ts",
    "index.ts",
    "validation.ts"
  ],
  "exclude": [
    "tests"
  ]
}
