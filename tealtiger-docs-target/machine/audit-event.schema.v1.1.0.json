{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://docs.tealtiger.ai/schemas/audit-event/1.1.0.json",
  "title": "TealTiger Audit Event",
  "description": "Canonical structure of audit events emitted by TealTiger decisions (v1.1.0).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "event",
    "correlation",
    "actor",
    "execution",
    "policy",
    "reason_codes",
    "actions",
    "redaction",
    "extensions"
  ],
  "properties": {
    "schema": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version"
      ],
      "properties": {
        "name": {
          "type": "string",
          "const": "tealtiger.audit_event"
        },
        "version": {
          "type": "string",
          "const": "1.1.0"
        }
      }
    },
    "event": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "type",
        "timestamp",
        "severity",
        "outcome"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "policy.decision",
            "policy.action",
            "policy.error",
            "policy.metric"
          ]
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "severity": {
          "type": "string"
        },
        "outcome": {
          "type": "string"
        }
      }
    },
    "correlation": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "trace_id",
        "span_id"
      ],
      "properties": {
        "trace_id": {
          "type": "string"
        },
        "span_id": {
          "type": "string"
        },
        "request_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "session_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "parent_event_id": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "actor": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "type",
        "id"
      ],
      "properties": {
        "type": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "display_name": {
          "type": [
            "string",
            "null"
          ]
        },
        "tenant_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "org_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "ip": {
          "type": [
            "string",
            "null"
          ]
        },
        "user_agent": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "environment"
      ],
      "properties": {
        "environment": {
          "type": "string"
        },
        "region": {
          "type": [
            "string",
            "null"
          ]
        },
        "runtime": {
          "type": [
            "string",
            "null"
          ]
        },
        "runtime_version": {
          "type": [
            "string",
            "null"
          ]
        },
        "host": {
          "type": [
            "string",
            "null"
          ]
        },
        "deployment": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "ai": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "policy": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "policy_id",
        "policy_version",
        "mode",
        "decision"
      ],
      "properties": {
        "policy_id": {
          "type": "string"
        },
        "policy_version": {
          "type": "string"
        },
        "mode": {
          "type": "string"
        },
        "decision": {
          "type": "string"
        },
        "matched": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "matched_rules": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        }
      }
    },
    "signals": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "reason_codes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "redaction": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "applied"
      ],
      "properties": {
        "applied": {
          "type": "boolean"
        }
      }
    },
    "error": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
