{
  "name": "github-mcp",
  "version": "1.0.0",
  "description": "Tool catalog for the GitHub MCP server. Classifies GitHub tooling by governance risk.",
  "protocol": "mcp",
  "database": "github",
  "riskLevels": {
    "READ": "Read-only discovery and inspection with no repository writes.",
    "MUTATING": "Alters repository, issue, or pull request state but is not inherently destructive.",
    "DESTRUCTIVE": "Can remove content, rewrite history paths, or force major release/access changes."
  },
  "tools": [
    {
      "name": "add_comment_to_pending_review",
      "risk": "MUTATING",
      "description": "Add review comment to the latest pending pull request review."
    },
    {
      "name": "add_issue_comment",
      "risk": "MUTATING",
      "description": "Add a comment to an issue."
    },
    {
