      "description": "Create a branch."
    },
    {
      "name": "create_or_update_file",
      "risk": "MUTATING",
      "description": "Create or update a repository file."
    },
    {
      "name": "create_pull_request",
      "risk": "MUTATING",
      "description": "Open new pull request."
    },
    {
