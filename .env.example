# TealTiger Observability Dashboard
# Copy this file to .env and fill in the values.

# Base URL for the REST API (e.g., local development server)
VITE_API_BASE_URL=http://localhost:4000/api

# WebSocket endpoint for real-time governance events
VITE_WS_URL=ws://localhost:4000/ws

# Optional: Application title
# VITE_APP_TITLE=TealTiger Dashboard

# Optional: Enable debug logging
# VITE_DEBUG=false

# Optional: Polling interval for historical data (ms)
# VITE_POLL_INTERVAL=30000