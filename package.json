{
  "name": "ai-agent-security-platform",
  "version": "0.1.0",
  "description": "Production-grade runtime security and governance for autonomous AI agents",
  "keywords": [
    "ai",
    "agents",
    "security",
    "governance",
    "oauth",
    "policy-engine",
    "zero-trust"
  ],
  "homepage": "https://github.com/yourusername/ai-agent-security-platform#readme",
  "bugs": {
    "url": "https://github.com/yourusername/ai-agent-security-platform/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yourusername/ai-agent-security-platform.git"
  },
  "license": "MIT",
  "author": "Your Name <your.email@example.com>",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "clean": "npm run clean --workspaces",
    "dev": "docker-compose up -d && npm run dev --workspaces",
    "lint": "eslint . --ext .ts,.js,.tsx,.jsx",
    "lint:fix": "eslint . --ext .ts,.js,.tsx,.jsx --fix",
    "test": "npm run test --workspaces",
    "test:coverage": "npm run test:coverage --workspaces",
    "test:e2e": "npm run test:e2e --workspaces",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "npm run typecheck --workspaces",
    "prepare": "husky install",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.45.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-prettier": "^5.0.0",
    "husky": "^8.0.3",
    "lint-staged": "^13.2.3",
    "prettier": "^3.0.0",
    "typescript": "^5.1.6",
    "vitepress": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "lint-staged": {
    "*.{ts,js,tsx,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{md,json,yml,yaml}": [
      "prettier --write"
    ]
  }
}