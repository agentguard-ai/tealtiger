{
  "name": "ai-agent-security-platform",
  "version": "0.1.0",
  "description": "Production-grade runtime security and governance for autonomous AI agents",
  "main": "src/app.js",
  "keywords": [
    "ai",
    "agents",
    "security",
    "governance",
    "oauth",
    "policy-engine",
    "zero-trust"
  ],
  "homepage": "https://github.com/nagasatish007/ai-agent-security-platform#readme",
  "bugs": {
    "url": "https://github.com/nagasatish007/ai-agent-security-platform/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nagasatish007/ai-agent-security-platform.git"
  },
  "license": "MIT",
  "author": "Satish Naga <nagasatish007@gmail.com>",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/ --ext .js",
    "lint:fix": "eslint src/ --ext .js --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "db:setup": "node scripts/setup-database.js",
    "db:start": "docker-compose up -d postgres",
    "db:stop": "docker-compose stop postgres",
    "db:reset": "docker-compose down -v && docker-compose up -d postgres && npm run db:setup",
    "prepare": "husky install"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "pg": "^8.17.2"
  },
  "devDependencies": {
    "eslint": "^8.45.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-prettier": "^5.0.0",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "lint-staged": "^13.2.3",
    "nodemon": "^3.0.2",
    "prettier": "^3.0.0",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{md,json,yml,yaml}": [
      "prettier --write"
    ]
  }
}
