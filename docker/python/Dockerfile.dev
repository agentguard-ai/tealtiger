# TealTiger Python SDK — Development Image
FROM python:3.12

LABEL maintainer="TealTiger Team <reachout@tealtiger.ai>"
LABEL org.opencontainers.image.title="TealTiger Python SDK (Dev)"
LABEL org.opencontainers.image.description="TealTiger Python SDK with development tools"
LABEL org.opencontainers.image.version="1.1.1"
LABEL org.opencontainers.image.licenses="Apache-2.0"

WORKDIR /app

RUN pip install --no-cache-dir \
    tealtiger \
    pytest pytest-asyncio pytest-cov \
    hypothesis mypy black isort ruff \
    ipython httpx

RUN useradd -m tealtiger && chown -R tealtiger:tealtiger /app
USER tealtiger

ENV PYTHONUNBUFFERED=1
CMD ["python"]
